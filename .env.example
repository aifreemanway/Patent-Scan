# Patent-Scan web app — required environment variables.
# Copy to .env.local and fill in values for local development.
# In Vercel, set these under Project Settings → Environment Variables.

# --- Gemini (Google Generative AI) ---
# Get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: override Gemini model by pointing at a different generateContent URL.
# Default: gemini-2.5-flash. Example: switch to 2.5-pro without code change.
# GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-pro:generateContent

# --- Rospatent PatSearch ---
# Token from https://searchplatform.rospatent.gov.ru/
PATSEARCH_TOKEN=

# Optional override for testing against staging endpoint:
# PATSEARCH_URL=https://searchplatform.rospatent.gov.ru/patsearch/v0.2/search

# --- EPO OPS (European Patent Office) ---
# Not currently used in any route but kept for future EPO integration.
EPO_KEY=
EPO_SECRET=

# --- Tavily (web search for /api/search-web) ---
# https://tavily.com/
TAVILY_API_KEY=

# --- Upstash Redis (rate-limit + anti-abuse) ---
# Auto-populated by Vercel Upstash integration. In local dev, optional —
# rate-limit falls back to in-memory (non-persistent).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Supabase (auth + DB) — B1 ---
# Dashboard → Settings → API. anon key is public (embedded in browser bundle),
# service_role key is SECRET (server-only).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare Turnstile (anti-bot) — B1 Этап 3.5 ---
# Get keys at https://dash.cloudflare.com → Turnstile → Add site
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
